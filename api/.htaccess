RewriteEngine On

# No reescribir si el archivo o directorio solicitado existe realmente.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]

# El .env nunca debe poder descargarse aunque alguien adivine la URL.
<FilesMatch "^\.env">
    Require all denied
</FilesMatch>
