# Copia este archivo a .env y completa los valores reales.
# .env NUNCA debe subirse a control de versiones (ver .gitignore).

# --- Base de datos ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=parqueadero_db
DB_USER=root
DB_PASS=

# --- Pasarela de SMS ---
# Interruptor general: en false, las notificaciones se encolan igual pero
# no se intenta enviar ningún SMS (útil mientras no haya un proveedor listo).
SMS_ENVIO_ACTIVO=true

# Proveedor activo: twilio | hablame | android | gsm
SMS_PROVIDER=twilio

# Twilio (cuenta trial para la demo)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Hablame.co (alternativa colombiana, dejar vacío mientras no se use)
HABLAME_API_KEY=
HABLAME_API_URL=

# Gateway con teléfono Android propio (app "SMS Gateway for Android",
# https://docs.sms-gate.app/ , modo "Local Server"): sin límite diario ni
# verificación de identidad, usa el plan de SMS que ya pagas del celular.
# ANDROID_GATEWAY_URL es la IP local que muestra la app, ej: http://192.168.1.50:8080
ANDROID_GATEWAY_URL=
ANDROID_GATEWAY_USER=
ANDROID_GATEWAY_PASSWORD=

# Módem GSM/3G USB conectado al servidor (Windows: aparece como puerto
# COMx en el Administrador de dispositivos). No requiere teléfono ni
# pasarela externa; el costo es el de la SIM que le pongas al módem.
GSM_MODEM_PORT=
GSM_MODEM_BAUD=9600

# --- Aplicación ---
APP_ENV=local
APP_DEBUG=true
